    },
    {
      "lang": "en",
      "name": "English",
      "path": "src/lang/en.json"
    }
  ],
  "url": "https://github.com/RaymundoJMSN/foundry-bulk-exporter",
  "manifest": "https://github.com/RaymundoJMSN/foundry-bulk-exporter/releases/latest/download/module.json",
